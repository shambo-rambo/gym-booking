# Database (Neon — use pooled URL for runtime, direct URL for Prisma migrations)
DATABASE_URL="postgresql://user:password@host/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/database"

# NextAuth v5
AUTH_SECRET="your-random-secret-here"   # openssl rand -base64 32
AUTH_URL="http://localhost:3000"         # set to your live URL in production

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# SMS (ClickSend) — Dashboard > API Credentials for username/API key
CLICKSEND_USERNAME="you@example.com"
CLICKSEND_API_KEY="xxxxxxxxxxxx"
CLICKSEND_SENDER_ID=""   # optional: approved alphanumeric sender (max 11 chars) or a dedicated number

# Cron job authentication — required for all cron jobs to work
# Generate with: openssl rand -base64 32
CRON_SECRET="your-random-cron-secret-here"

# Inner Range Inception access control (read-only — used for the weekly amenity audit)
INCEPTION_BASE_URL=""
INCEPTION_API_USERNAME=""
INCEPTION_API_PASSWORD=""
INCEPTION_AMENITY_WHERE_ID=""   # WhereID of the shared Gym/Sauna door

# Building resident self-verification code
BUILDING_CODE="your-building-code-here"

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@yourdomain.com"

# Two-Factor Authentication (TOTP) — encrypts stored secrets & hashes backup codes
# Generate with: openssl rand -base64 32
TWO_FACTOR_ENCRYPTION_KEY="your-32-byte-base64-key-here"
